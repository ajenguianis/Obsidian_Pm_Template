# -----------------------------
# Public repo policy
# Keep structure, exclude private note content
# -----------------------------

# OS / editor noise
.DS_Store
Thumbs.db

# Obsidian local/private runtime files
.obsidian/cache/
.obsidian/workspace.json
.obsidian/workspaces.json
.obsidian/plugins/
.obsidian/hotkeys.json

# =============================
# Keep folder structure only
# (allow .gitkeep placeholders)
# =============================

# Clients
👤 Clients/**
!👤 Clients/.gitkeep

# Projects (if sensitive)
📌 Projects/**
!📌 Projects/.gitkeep

# Customer demands
📥 Customer Demands/**
!📥 Customer Demands/.gitkeep
!📥 Customer Demands/📁 Requests/
📥 Customer Demands/📁 Requests/**
!📥 Customer Demands/📁 Requests/.gitkeep

# Internal requests
⚙️ Internal Requests/**
!⚙️ Internal Requests/.gitkeep

# Archive
🗄️ Archive/**
!🗄️ Archive/.gitkeep

# Daily notes
🗒️ Daily/**
!🗒️ Daily/.gitkeep

# Optional sensitive note areas
📑 Notes/**
!📑 Notes/.gitkeep

# Excalidraw drawings (keep folder only)
🎨 Excalidraw/Drawings/**
!🎨 Excalidraw/Drawings/.gitkeep

# Binary attachments (safety)
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.docx
*.xlsx
*.pptx
*.zip
# IDE folders
.idea/
.vscode/
.vccode/
